{
  "name": "salesforce-enterprise-platform",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky install",
    "lint": "eslint force-app --ext .js,.html",
    "pmd": "sf scanner run --target-org SCRATCH --target force-app",
    "format": "prettier --write .",
    "test": "echo \"Run Apex tests with Salesforce CLI in a connected org\"",
    "deploy": "sf project deploy start --target-org SCRATCH",
    "validate": "npm run lint && npm run pmd"
  },
  "devDependencies": {
    "@salesforce/eslint-config-lwc": "^3",
    "eslint": "^9",
    "prettier": "^3",
    "husky": "^9",
    "lint-staged": "^15",
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19"
  }
}
